  "html": "<style>\n* { box-sizing: border-box; margin: 0; padding: 0; }\n.pf-wrap { font-family: Arial, sans-serif; font-size: 8.5pt; color: #000; width: 100%; padding: 6mm 8mm; background: #fff; }\n.pf-banner { background: #1B3A6B !important; -webkit-print-color-adjust: exact; print-color-adjust: exact; color: #fff !important; text-align: center; font-weight: bold; font-size: 9pt; letter-spacing: 4px; text-transform: uppercase; padding: 4px 0; margin-bottom: 5px; }\n.pf-header { display: flex; justify-content: space-between; align-items: flex-start; border-bottom: 2px solid #1B3A6B; padding-bottom: 5px; margin-bottom: 6px; }\n.pf-logo img { height: 52px; width: auto; display: block; }\n.pf-logo .tagline { font-size: 6pt; color: #1B3A6B; font-weight: bold; text-transform: uppercase; letter-spacing: 2px; margin-top: 2px; }\n.pf-doctitle { text-align: right; line-height: 1; }\n.pf-doctitle .big { font-size: 20pt; font-weight: bold; color: #1B3A6B; text-transform: uppercase; }\n.pf-doctitle .sub { font-size: 12pt; font-weight: bold; color: #1B3A6B; text-transform: uppercase; }\n.pf-info-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 5px; margin-bottom: 5px; }\n.pf-info-tbl { width: 100%; border-collapse: collapse; font-size: 7.5pt; }\n.pf-info-tbl td { padding: 3px 5px; border: 1px solid #b0bccc; vertical-align: middle; line-height: 1.2; }\n.pf-info-tbl .lbl { background: #1B3A6B !important; -webkit-print-color-adjust: exact; print-color-adjust: exact; color: #fff !important; font-weight: bold; font-size: 6.5pt; text-transform: uppercase; white-space: nowrap; width: 42%; }\n.pf-info-tbl .val { background: #fff; }\n.pf-instruction { font-size: 7.5pt; font-style: italic; color: #1B3A6B; font-weight: bold; margin: 4px 0 3px 0; }\n.pf-items { width: 100%; border-collapse: collapse; font-size: 7.5pt; }\n.pf-items thead tr { background: #1B3A6B !important; -webkit-print-color-adjust: exact; print-color-adjust: exact; color: #fff !important; }\n.pf-items thead th { padding: 4px 3px; text-align: center; font-size: 7pt; font-weight: bold; text-transform: uppercase; border: 1px solid #1B3A6B; line-height: 1.2; }\n.pf-items tbody td { padding: 3px 4px; border: 1px solid #b0bccc; vertical-align: middle; text-align: center; height: 18px; font-size: 7.5pt; }\n.pf-items tbody td.txt-left { text-align: left; }\n.pf-items tbody tr:nth-child(even) { background: #EEF3FA !important; -webkit-print-color-adjust: exact; print-color-adjust: exact; }\n.pf-conf { margin-top: 6px; border: 1px solid #1B3A6B; }\n.pf-conf-title { background: #1B3A6B !important; -webkit-print-color-adjust: exact; print-color-adjust: exact; color: #fff !important; font-weight: bold; font-size: 7.5pt; text-transform: uppercase; text-align: center; padding: 4px; letter-spacing: 2px; }\n.pf-conf-grid { display: grid; grid-template-columns: 1fr 1fr 1fr 1fr; }\n.pf-conf-cell { border-right: 1px solid #b0bccc; padding: 5px 6px; min-height: 52px; }\n.pf-conf-cell:last-child { border-right: none; }\n.pf-conf-lbl { font-size: 6.5pt; font-weight: bold; text-transform: uppercase; color: #1B3A6B; margin-bottom: 3px; border-bottom: 1px solid #b0bccc; padding-bottom: 2px; }\n.pf-box { border: 1px solid #b0bccc; margin-top: 5px; }\n.pf-box-title { background: #1B3A6B !important; -webkit-print-color-adjust: exact; print-color-adjust: exact; color: #fff !important; font-weight: bold; font-size: 6.5pt; text-transform: uppercase; padding: 3px 6px; letter-spacing: 1px; }\n.pf-box-body { padding: 4px 6px; min-height: 30px; font-size: 7.5pt; }\n.pf-footer { margin-top: 5px; border-top: 1.5px solid #1B3A6B; padding-top: 3px; display: flex; justify-content: space-between; font-size: 6.5pt; color: #555; }\n</style>\n\n<div class=\"pf-wrap\">\n  <div class=\"pf-banner\">B O N &nbsp; D E &nbsp; R É C E P T I O N</div>\n  <div class=\"pf-header\">\n    <div class=\"pf-logo\">\n<img class=\"bc-logo\" src=\"/files/logoISQ.png\">\n<div class=\"tagline\">Réalisateur de Projets</div>\n    </div>\n    <div class=\"pf-doctitle\">\n      <div class=\"big\">BON DE</div>\n      <div class=\"sub\">RÉCEPTION</div>\n    </div>\n  </div>\n\n  <div class=\"pf-info-grid\">\n    <table class=\"pf-info-tbl\">\n      <tr><td class=\"lbl\">Service / Chantier</td><td class=\"val\">{{ doc.service__chantier or \"\" }}</td></tr>\n      <tr><td class=\"lbl\">Demandé Par</td><td class=\"val\">{{ doc.demandé_par or \"\" }}</td></tr>\n      <tr><td class=\"lbl\">Nom Fournisseur</td><td class=\"val\"><strong>{{ doc.nom_fournisseur or \"\" }}</strong></td></tr>\n    </table>\n    <table class=\"pf-info-tbl\">\n      <tr><td class=\"lbl\">Numéro BR</td><td class=\"val\"><strong>{{ doc.name }}</strong></td></tr>\n      <tr><td class=\"lbl\">Date de Réception</td><td class=\"val\">{{ doc.date_de_réception or \"\" }}</td></tr>\n      <tr><td class=\"lbl\">Référence BC</td><td class=\"val\">{{ doc.get(\"référence_bc\") or \"\" }}</td></tr>\n    </table>\n  </div>\n\n  <div class=\"pf-instruction\">Articles réceptionnés :</div>\n\n  <table class=\"pf-items\">\n    <thead>\n      <tr>\n        <th style=\"width:4%;\">N°</th>\n        <th style=\"width:18%;\">Numéro Article</th>\n        <th style=\"width:50%;\">Description Produit / Service</th>\n        <th style=\"width:13%;\">Unité</th>\n        <th style=\"width:15%;\">Quantité Reçue</th>\n      </tr>\n    </thead>\n    <tbody>\n      {% for item in doc.articles_bc %}\n      <tr>\n        <td>{{ loop.index }}</td>\n        <td>{{ item.numéro_article or \"\" }}</td>\n        <td class=\"txt-left\">{{ item.description_produitservice or \"\" }}</td>\n        <td>{{ item.unité or \"\" }}</td>\n        <td>{{ item.quantité_reçue if item.quantité_reçue is not none else \"\" }}</td>\n      </tr>\n      {% endfor %}\n      {% for i in range([8 - doc.articles_bc|length, 0]|max) %}\n      <tr><td>&nbsp;</td><td></td><td></td><td></td><td></td></tr>\n      {% endfor %}\n    </tbody>\n  </table>\n\n  <div class=\"pf-conf\">\n    <div class=\"pf-conf-title\">Contrôle de Conformité</div>\n    <div class=\"pf-conf-grid\">\n      <div class=\"pf-conf-cell\">\n        <div class=\"pf-conf-lbl\">Réceptionné Par</div>\n        <div style=\"font-size:6.5pt;color:#555;margin-top:6px;\">Nom :</div>\n        <div style=\"font-size:6.5pt;color:#555;margin-top:8px;\">Signature :</div>\n      </div>\n      <div class=\"pf-conf-cell\">\n        <div class=\"pf-conf-lbl\">Vérifié Par</div>\n        <div style=\"font-size:6.5pt;color:#555;margin-top:6px;\">Nom :</div>\n        <div style=\"font-size:6.5pt;color:#555;margin-top:8px;\">Signature :</div>\n      </div>\n      <div class=\"pf-conf-cell\">\n        <div class=\"pf-conf-lbl\">Conforme</div>\n        <div style=\"margin-top:8px;font-size:8.5pt;line-height:2;\">☐ &nbsp;OUI<br>☐ &nbsp;NON</div>\n      </div>\n      <div class=\"pf-conf-cell\">\n        <div class=\"pf-conf-lbl\">Approuvé Par</div>\n        <div style=\"font-size:6.5pt;color:#555;margin-top:6px;\">Nom :</div>\n        <div style=\"font-size:6.5pt;color:#555;margin-top:8px;\">Signature :</div>\n      </div>\n    </div>\n  </div>\n\n  <div class=\"pf-box\">\n    <div class=\"pf-box-title\">Commentaires / Réserves</div>\n    <div class=\"pf-box-body\"></div>\n  </div>\n\n  <div class=\"pf-footer\">\n    <span><strong>ISQUARE SARL</strong> — Tanger, Maroc</span>\n    <span>{{ doc.name }} &nbsp;|&nbsp; {{ doc.date_de_réception or \"\" }}</span>\n  </div>\n</div>",
