  "html": "<style>\n@page { \n  size: A4 !important; \n  margin: 10mm 10mm 20mm 10mm !important; \n  @bottom-center {\n    content: \"4, Immeuble Aurelia 61 Rue Abou Alae Maari – TANGER Maroc – Email : info@isquare.ma – Site web : www.isquare.ma\\A Tél : 0531028946 - RC. : 114061 – Patente n° 50409828 – I.F. : 50130268 – ICE : 002730874000079 – Capital : 3.000.000 DH\";\n    font-family: Arial, sans-serif !important;\n    font-size: 7.5pt !important;\n    color: #555 !important;\n    white-space: pre-wrap !important;\n    line-height: 1.4 !important;\n    border-top: 1px solid #c9ced4 !important;\n    width: 100% !important;\n  }\n}\n.print-format, .print-format table, .br, .br table { margin: 0; padding: 0; border-collapse: collapse !important; }\n.br { font-family: Arial, sans-serif !important; color: #222 !important; font-size: 9.5pt !important; width: 100% !important; }\n.br-head { width: 100% !important; margin-bottom: 12px !important; }\n.br-head td { vertical-align: top !important; padding: 0 !important; }\n.br-logo-cell { text-align: left !important; }\n.br-logo { height: 44px !important; width: auto !important; max-width: 200px !important; object-fit: contain !important; display: block !important; margin: 0 0 2px 0 !important; }\n.br-slogan { color: #8a929b !important; font-size: 8pt !important; letter-spacing: 1px !important; display: block !important; }\n.br-title { text-align: right !important; color: #2c3e50 !important; font-weight: 300 !important; line-height: 1.05 !important; }\n.br-title .l1 { font-size: 21pt !important; letter-spacing: 1px !important; }\n.br-title .l2 { font-size: 14pt !important; letter-spacing: 1px !important; }\n.br-info { width: 100% !important; margin-bottom: 12px !important; }\n.br-grid { width: 100% !important; }\n.br-grid td { border: 1px solid #c9ced4 !important; padding: 3px 6px !important; font-size: 8.5pt !important; }\n.br-grid .h { background: #2c3e50 !important; color: #fff !important; -webkit-print-color-adjust: exact !important; print-color-adjust: exact !important; font-weight: bold !important; text-align: center !important; }\n.br-grid .v { background: #f0f1f3 !important; -webkit-print-color-adjust: exact !important; print-color-adjust: exact !important; text-align: center !important; height: 14px !important; }\n.br-amount-box { border: 2px solid #2c3e50 !important; padding: 12px !important; text-align: center !important; margin: 15px 0 !important; }\n.br-amount-label { font-size: 9pt !important; color: #555 !important; }\n.br-amount-value { font-size: 18pt !important; font-weight: bold !important; color: #2c3e50 !important; margin: 4px 0 !important; }\n.br-amount-words { font-style: italic !important; font-size: 9pt !important; }\n.br-sig { width: 100% !important; margin-top: 20px !important; border-collapse: collapse !important; }\n.br-sig th { background: #2c3e50 !important; color: #fff !important; -webkit-print-color-adjust: exact !important; print-color-adjust: exact !important; padding: 5px !important; font-size: 8.5pt !important; border: 1px solid #c9ced4 !important; }\n.br-sig td { border: 1px solid #c9ced4 !important; padding: 8px !important; font-size: 9pt !important; height: 40px !important; vertical-align: top !important; }\n.br-com { background: #2c3e50 !important; color: #fff !important; -webkit-print-color-adjust: exact !important; print-color-adjust: exact !important; text-align: center !important; font-weight: bold !important; font-size: 9pt !important; padding: 5px !important; margin-top: 15px !important; }\n.br-com-box { border: 1px solid #c9ced4 !important; border-top: none !important; padding: 12px 15px !important; min-height: 50px !important; font-size: 9.5pt !important; }\n</style>\n\n<div class=\"br\">\n  <table class=\"br-head\">\n    <tr>\n      <td style=\"width:60%;\" class=\"br-logo-cell\">\n        <img class=\"br-logo\" src=\"/files/logoISQ.png\">\n        <span class=\"br-slogan\">REALISATEUR DE PROJETS</span>\n      </td>\n      <td style=\"width:40%;\" class=\"br-title\">\n        <div class=\"l1\">BON DE</div>\n        <div class=\"l2\">RÈGLEMENT</div>\n      </td>\n    </tr>\n  </table>\n\n  <table class=\"br-info\">\n    <tr>\n      <td style=\"width:56%;\">\n        <table class=\"br-grid\">\n          <tr><td class=\"h\">FOURNISSEUR</td><td class=\"h\">MODE DE PAIEMENT</td></tr>\n          <tr><td class=\"v\">{{ doc.fournisseur or \"\" }}</td>\n              <td class=\"v\">{{ doc.mode_paiement or \"\" }}</td></tr>\n          <tr><td class=\"h\">RÉFÉRENCE BC</td><td class=\"h\">RÉFÉRENCE BR</td></tr>\n          <tr><td class=\"v\">{{ doc.reference_bc or \"\" }}</td>\n              <td class=\"v\">{{ doc.reference_br or \"\" }}</td></tr>\n        </table>\n      </td>\n      <td style=\"width:4%;\"></td>\n      <td style=\"width:40%;\">\n        <table class=\"br-grid\">\n          <tr><td class=\"h\">NUMERO BREGL</td><td class=\"h\">DATE D'ÉCHÉANCE</td></tr>\n          <tr><td class=\"v\">{{ doc.name }}</td>\n              <td class=\"v\">{{ frappe.utils.format_date(doc.date_echeance) if doc.date_echeance else \"\" }}</td></tr>\n          <tr><td class=\"h\">STATUT</td><td class=\"h\" style=\"border:none; background:#fff !important;\"></td></tr>\n          <tr><td class=\"v\">{{ doc.statut or doc.workflow_state or \"\" }}</td>\n              <td class=\"v\" style=\"border:none; background:#fff !important;\"></td></tr>\n        </table>\n      </td>\n    </tr>\n  </table>\n\n  <div class=\"br-amount-box\">\n    <div class=\"br-amount-label\">MONTANT À RÉGLER</div>\n    <div class=\"br-amount-value\">{{ \"%.2f\"|format(doc.montant_a_regler) }} MAD</div>\n    <div class=\"br-amount-words\">({{ frappe.utils.money_in_words(doc.montant_a_regler, \"MAD\") }})</div>\n  </div>\n\n  <table class=\"br-sig\">\n    <tr>\n      <th style=\"width:50%;\">VÉRIFIÉ PAR</th>\n      <th style=\"width:50%;\">APPROUVÉ PAR</th>\n    </tr>\n    <tr>\n      <td>{{ doc.verifie_par or \"\" }}<br><br>Date : ____________<br>Signature :</td>\n      <td>{{ doc.approuve_par or \"\" }}<br><br>Date : ____________<br>Signature :</td>\n    </tr>\n  </table>\n\n  <div class=\"br-com\">COMMENTAIRES</div>\n  <div class=\"br-com-box\">{{ doc.commentaire or \"\" }}</div>\n</div>",
