  "html": "<style>\n@page { \n  size: A4 !important; \n  margin: 10mm 10mm 20mm 10mm !important; \n  @bottom-center {\n    content: \"4, Immeuble Aurelia 61 Rue Abou Alae Maari – TANGER Maroc – Email : info@isquare.ma – Site web : www.isquare.ma\\A Tél : 0531028946 - RC. : 114061 – Patente n° 50409828 – I.F. : 50130268 – ICE : 002730874000079 – Capital : 3.000.000 DH\";\n    font-family: Arial, sans-serif !important;\n    font-size: 7.5pt !important;\n    color: #555 !important;\n    white-space: pre-wrap !important;\n    line-height: 1.4 !important;\n    border-top: 1px solid #c9ced4 !important;\n    width: 100% !important;\n  }\n}\n.print-format, .print-format table, .dd, .dd table { margin: 0; padding: 0; border-collapse: collapse !important; }\n.dd { font-family: Arial, sans-serif !important; color: #222 !important; font-size: 9.5pt !important; width: 100% !important; }\n.dd-head { width: 100% !important; margin-bottom: 12px !important; }\n.dd-head td { vertical-align: top !important; padding: 0 !important; }\n.dd-logo-cell { text-align: left !important; }\n.dd-logo { height: 44px !important; width: auto !important; max-width: 200px !important; object-fit: contain !important; display: block !important; margin: 0 0 2px 0 !important; }\n.dd-slogan { color: #8a929b !important; font-size: 8pt !important; letter-spacing: 1px !important; display: block !important; }\n.dd-title { text-align: right !important; color: #2c3e50 !important; font-weight: 300 !important; line-height: 1.05 !important; }\n.dd-title .l1 { font-size: 21pt !important; letter-spacing: 1px !important; }\n.dd-title .l2 { font-size: 14pt !important; letter-spacing: 1px !important; }\n.dd-info { width: 100% !important; margin-bottom: 12px !important; }\n.dd-grid { width: 100% !important; }\n.dd-grid td { border: 1px solid #c9ced4 !important; padding: 3px 6px !important; font-size: 8.5pt !important; }\n.dd-grid .h { background: #2c3e50 !important; color: #fff !important; -webkit-print-color-adjust: exact !important; print-color-adjust: exact !important; font-weight: bold !important; text-align: center !important; }\n.dd-grid .v { background: #f0f1f3 !important; -webkit-print-color-adjust: exact !important; print-color-adjust: exact !important; text-align: center !important; height: 14px !important; }\n.dd-lead { margin: 0 0 12px 0 !important; font-size: 9.5pt !important; }\n.dd-items { width: 100% !important; margin-bottom: 15px !important; }\n.dd-items th { background: #2c3e50 !important; color: #fff !important; -webkit-print-color-adjust: exact !important; print-color-adjust: exact !important; padding: 5px 6px !important; font-size: 8.5pt !important; text-align: center !important; border: 1px solid #c9ced4 !important; }\n.dd-items td { border: 1px solid #c9ced4 !important; padding: 4px 6px !important; font-size: 9pt !important; height: 18px !important; }\n.dd-items .c { text-align: center !important; }\n.dd-sa { color: #2c3e50 !important; font-weight: bold !important; font-size: 9.5pt !important; border-top: 2px solid #c9ced4 !important; padding-top: 5px !important; margin-bottom: 4px !important; }\n.dd-syn-row-retenu td { background: #e8f5e9 !important; -webkit-print-color-adjust: exact !important; print-color-adjust: exact !important; font-weight: bold !important; }\n.dd-com { background: #2c3e50 !important; color: #fff !important; -webkit-print-color-adjust: exact !important; print-color-adjust: exact !important; text-align: center !important; font-weight: bold !important; font-size: 9pt !important; padding: 5px !important; margin-top: 4px !important; }\n.dd-com-box { border: 1px solid #c9ced4 !important; border-top: none !important; padding: 12px 15px !important; min-height: 60px !important; font-size: 9.5pt !important; }\n</style>\n\n<div class=\"dd\">\n  <table class=\"dd-head\">\n    <tr>\n      <td style=\"width:60%;\" class=\"dd-logo-cell\">\n        <img class=\"dd-logo\" src=\"/files/logoISQ.png\">\n        <span class=\"dd-slogan\">REALISATEUR DE PROJETS</span>\n      </td>\n      <td style=\"width:40%;\" class=\"dd-title\">\n        <div class=\"l1\">DEMANDE</div>\n        <div class=\"l2\">DE DEVIS</div>\n      </td>\n    </tr>\n  </table>\n\n  <table class=\"dd-info\">\n    <tr>\n      <td style=\"width:56%;\">\n        <table class=\"dd-grid\">\n          <tr><td class=\"h\">RÉFÉRENCE DA</td><td class=\"h\">CHANTIER</td></tr>\n          <tr><td class=\"v\">{{ doc.reference_da or \"\" }}</td>\n              <td class=\"v\">{{ doc.service_chantier or \"\" }}</td></tr>\n          <tr><td class=\"h\">MODE D'ENVOI</td><td class=\"h\">STATUT</td></tr>\n          <tr><td class=\"v\">{{ doc.mode_envoi or \"\" }}</td>\n              <td class=\"v\">{{ doc.statut_dd or \"\" }}</td></tr>\n        </table>\n      </td>\n      <td style=\"width:4%;\"></td>\n      <td style=\"width:40%;\">\n        <table class=\"dd-grid\">\n          <tr><td class=\"h\">NUMERO DD</td><td class=\"h\">DATE DE DEMANDE</td></tr>\n          <tr><td class=\"v\">{{ doc.name }}</td>\n              <td class=\"v\">{{ frappe.utils.format_date(doc.date_demande) if doc.date_demande else \"\" }}</td></tr>\n          <tr><td class=\"h\">DATE LIMITE RÉPONSE</td><td class=\"h\" style=\"border:none; background:#fff !important;\"></td></tr>\n          <tr><td class=\"v\">{{ frappe.utils.format_date(doc.date_limite_reponse) if doc.date_limite_reponse else \"\" }}</td>\n              <td class=\"v\" style=\"border:none; background:#fff !important;\"></td></tr>\n        </table>\n      </td>\n    </tr>\n  </table>\n\n  <p class=\"dd-lead\">Prière de faire parvenir vos meilleures offres pour les articles ci-après</p>\n\n  <table class=\"dd-items\">\n    <thead>\n      <tr>\n        <th style=\"width:15%;\">ARTICLE</th>\n        <th style=\"width:55%;\">DESCRIPTION</th>\n        <th style=\"width:15%;\">UNITÉ</th>\n        <th style=\"width:15%;\">QTÉ</th>\n      </tr>\n    </thead>\n    <tbody>\n      {% for it in doc.articles %}\n      <tr>\n        <td class=\"c\">{{ it.article or \"\" }}</td>\n        <td>{{ it.description or \"\" }}</td>\n        <td class=\"c\">{{ it.unite or \"\" }}</td>\n        <td class=\"c\">{{ it.quantite or \"\" }}</td>\n      </tr>\n      {% endfor %}\n    </tbody>\n  </table>\n\n  <div class=\"dd-sa\">FOURNISSEURS CONSULTÉS</div>\n  <table class=\"dd-items\" style=\"margin-bottom:15px;\">\n    <thead>\n      <tr>\n        <th style=\"width:35%;\">FOURNISSEUR</th>\n        <th style=\"width:20%;\">TÉLÉPHONE</th>\n        <th style=\"width:20%;\">CANAL</th>\n        <th style=\"width:25%;\">STATUT</th>\n      </tr>\n    </thead>\n    <tbody>\n      {% for f in doc.fournisseurs %}\n      <tr>\n        <td>{{ f.fournisseur }}</td>\n        <td class=\"c\">{{ f.telephone }}</td>\n        <td class=\"c\">{{ f.canal }}</td>\n        <td class=\"c\">{{ f.statut }}</td>\n      </tr>\n      {% endfor %}\n    </tbody>\n  </table>\n\n  <div class=\"dd-sa\">SYNTHÈSE DES DEVIS REÇUS</div>\n  <table class=\"dd-items\">\n    <thead>\n      <tr>\n        <th style=\"width:20%;\">FOURNISSEUR</th>\n        <th style=\"width:15%;\">N° DEVIS</th>\n        <th style=\"width:15%;\">ARTICLE</th>\n        <th style=\"width:12%;\">PRIX U.</th>\n        <th style=\"width:10%;\">QTÉ</th>\n        <th style=\"width:18%;\">TOTAL HT</th>\n        <th style=\"width:10%;\">RETENU</th>\n      </tr>\n    </thead>\n    <tbody>\n      {% for s in doc.synthese_devis %}\n      <tr {{ \"class=dd-syn-row-retenu\" if s.retenu else \"\" }}>\n        <td>{{ s.fournisseur }}</td>\n        <td class=\"c\">{{ s.numero_devis }}</td>\n        <td class=\"c\">{{ s.article }}</td>\n        <td class=\"c\">{{ \"%.2f\"|format(s.prix_unitaire) }}</td>\n        <td class=\"c\">{{ s.quantite }}</td>\n        <td class=\"c\">{{ \"%.2f\"|format(s.total_ht) }} MAD</td>\n        <td class=\"c\">{{ \"✓\" if s.retenu else \"\" }}</td>\n      </tr>\n      {% endfor %}\n    </tbody>\n  </table>\n\n  <div class=\"dd-com\">COMMENTAIRES</div>\n  <div class=\"dd-com-box\">{{ doc.commentaire or \"\" }}</div>\n</div>",
