  "html": "{% macro mad(v) -%}\n{{ \"{:,.2f}\".format(v or 0).replace(\",\", \"@\").replace(\".\", \",\").replace(\"@\", \" \") }}\n{%- endmacro %}\n\n<div class=\"bc\">\n\n  <table class=\"bc-head\">\n    <tr>\n      <td style=\"width:60%;\" class=\"bc-logo-cell\">\n        <img class=\"bc-logo\" src=\"/files/logoISQ.png\">\n        <span class=\"bc-slogan\">REALISATEUR DE PROJETS</span>\n      </td>\n      <td style=\"width:40%;\" class=\"bc-title\">\n        <div class=\"l1\">BON</div>\n        <div class=\"l2\">DE COMMANDE</div>\n      </td>\n    </tr>\n  </table>\n\n  <table class=\"bc-info\">\n    <tr>\n      <td style=\"width:56%;\">\n        <table class=\"bc-grid\">\n          <tr><td class=\"h\">DEMANDÉ PAR</td><td class=\"h\">CONTACT</td></tr>\n          <tr><td class=\"v\">{{ doc[\"demandé_par\"] or \"\" }}</td>\n              <td class=\"v\">{{ doc[\"contact_isq\"] or \"\" }}</td></tr>\n          <tr><td class=\"h\">BUT / UTILISATION</td><td class=\"h\">SERVICE / CHANTIER</td></tr>\n          <tr><td class=\"v\">{{ doc[\"but_utilisation\"] or \"\" }}</td>\n              <td class=\"v\">{{ doc[\"service__chantier\"] or \"\" }}</td></tr>\n          <tr><td class=\"h\">NOM DU FOURNISSEUR</td><td class=\"h\">POINT DE CONTACT</td></tr>\n          <tr><td class=\"v\">{{ doc[\"nom_du_fournisseur\"] or \"\" }}</td>\n              <td class=\"v\">{{ doc[\"point_de_contact\"] or \"\" }}</td></tr>\n        </table>\n      </td>\n      <td style=\"width:4%;\"></td>\n      <td style=\"width:40%;\">\n        <table class=\"bc-grid\">\n          <tr><td class=\"h\">NUMERO DE BC</td><td class=\"h\">DATE DE BC</td></tr>\n          <tr><td class=\"v\">{{ doc.name }}</td>\n              <td class=\"v\">{{ frappe.utils.format_date(doc[\"date_de_bc\"]) if doc[\"date_de_bc\"] else \"\" }}</td></tr>\n          <tr><td class=\"h\">N° DE DEVIS FOURNISSEUR</td><td class=\"h\">DATE DE DEVIS</td></tr>\n          <tr><td class=\"v\">{{ doc[\"n_devis_fournisseur\"] or \"\" }}</td>\n              <td class=\"v\">{{ frappe.utils.format_date(doc[\"date_du_devis\"]) if doc[\"date_du_devis\"] else \"\" }}</td></tr>\n          <tr><td class=\"h\" style=\"border:none; background:#fff !important;\"></td>\n              <td class=\"h\">DATE DE BESOIN</td></tr>\n          <tr><td class=\"v\" style=\"border:none; background:#fff !important;\"></td>\n              <td class=\"v\">{{ frappe.utils.format_date(doc[\"date_de_besoin\"]) if doc[\"date_de_besoin\"] else \"\" }}</td></tr>\n        </table>\n      </td>\n    </tr>\n  </table>\n\n  <p class=\"bc-lead\">Prière procéder à la fourniture des produits ci-après</p>\n\n  <table class=\"bc-items\">\n    <thead>\n      <tr>\n        <th style=\"width:18%;\">NUMÉRO D'ARTICLE</th>\n        <th style=\"width:40%;\">DESCRIPTION DU PRODUIT / SERVICE</th>\n        <th style=\"width:8%;\">UNITE</th>\n        <th style=\"width:8%;\">QTE</th>\n        <th style=\"width:13%;\">PRIX UNITAIRE H.T</th>\n        <th style=\"width:13%;\">TOTAL</th>\n      </tr>\n    </thead>\n    <tbody>\n      {% set lignes = doc.articles_bc %}\n      {% for it in lignes %}\n      <tr>\n        <td class=\"c\">{{ it[\"numéro_article\"] or \"\" }}</td>\n        <td>{{ it[\"description_produit_service\"] or \"\" }}</td>\n        <td class=\"c\">{{ it[\"unité\"] or \"\" }}</td>\n        <td class=\"c\">{{ it[\"quantité\"] or \"\" }}</td>\n        <td class=\"r\">{{ mad(it[\"prix_unitaire_ht\"]) }}</td>\n        <td class=\"r\">{{ mad((it[\"quantité\"] or 0) * (it[\"prix_unitaire_ht\"] or 0)) }}</td>\n      </tr>\n      {% endfor %}\n      {% for i in range(11 - (lignes|length)) %}\n      <tr><td>&nbsp;</td><td></td><td></td><td></td><td></td><td></td></tr>\n      {% endfor %}\n    </tbody>\n  </table>\n\n  <div class=\"bc-tot-wrapper\">\n    <table class=\"bc-tot\">\n      <tr><td class=\"lbl\">TOTAL H.T</td><td class=\"val\">{{ mad(doc[\"total_ht\"]) }}</td></tr>\n      {% if doc[\"montant_remise\"] %}\n      <tr><td class=\"lbl\">REMISE</td><td class=\"val\">- {{ mad(doc[\"montant_remise\"]) }}</td></tr>\n      {% endif %}\n      <tr><td class=\"lbl\">TVA 20%</td><td class=\"val\">{{ mad(doc[\"tva_20\"]) }}</td></tr>\n      <tr class=\"ttc\"><td class=\"lbl\">TOTAL TTC</td><td class=\"val\">{{ mad(doc[\"total_ttc\"]) }}</td></tr>\n    </table>\n  </div>\n\n  <div style=\"clear:both;\"></div>\n\n  <div class=\"bc-sa\">SERVICE DES ACHATS</div>\n  <div class=\"bc-com\">COMMENTAIRES</div>\n  <div class=\"bc-com-box\">{{ doc[\"commentaire\"] or \"\" }}</div>\n\n  <div class=\"bc-foot\">\n    4, Immeuble Aurelia 61 Rue Abou Alae Maari – TANGER Maroc – Email : info@isquare.ma – Site web : www.isquare.ma<br>\n    Tél : 0531028946 - RC. : 114061 – Patente n° 50409828 – I.F. : 50130268 – ICE : 002730874000079 – Capital : 3.000.000 DH\n  </div>\n\n</div>",
