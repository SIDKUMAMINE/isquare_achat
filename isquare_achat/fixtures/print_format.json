  "css": "@page { \n  size: A4 !important; \n  margin: 8mm 10mm 15mm 10mm !important; \n}\n\n/* Conteneur principal */\n.print-format, .print-format table, .bc, .bc table {\n  margin: 0;\n  padding: 0;\n  border-collapse: collapse !important;\n}\n\n.bc { \n  font-family: Arial, sans-serif !important; \n  color: #222 !important; \n  font-size: 9.5pt !important; \n  width: 100% !important;\n  position: relative !important;\n  min-height: 262mm !important; /* Fixe le pied de page en bas de la page A4 */\n}\n\n/* En-tête */\n.bc-head { \n  width: 100% !important; \n  margin-bottom: 12px !important; \n}\n\n.bc-head td { \n  vertical-align: top !important; \n  padding: 0 !important; \n}\n\n.bc-logo-cell { text-align: left !important; }\n.bc-logo { \n  height: 44px !important; \n  width: auto !important; \n  max-width: 200px !important; \n  object-fit: contain !important; \n  display: block !important; \n  margin: 0 0 2px 0 !important; \n}\n\n.bc-slogan { \n  color: #8a929b !important; \n  font-size: 8pt !important; \n  letter-spacing: 1px !important; \n  display: block !important; \n}\n\n.bc-title { \n  text-align: right !important; \n  color: #2c3e50 !important; \n  font-weight: 300 !important; \n  line-height: 1.05 !important; \n}\n.bc-title .l1 { font-size: 21pt !important; letter-spacing: 1px !important; }\n.bc-title .l2 { font-size: 14pt !important; letter-spacing: 1px !important; }\n\n/* Blocs d'informations supérieurs */\n.bc-info { \n  width: 100% !important; \n  margin-bottom: 12px !important; \n}\n\n.bc-grid { width: 100% !important; }\n.bc-grid td { \n  border: 1px solid #c9ced4 !important; \n  padding: 3px 6px !important; \n  font-size: 8.5pt !important; \n}\n\n.bc-grid .h {\n  background: #2c3e50 !important; \n  color: #fff !important;\n  -webkit-print-color-adjust: exact !important; \n  print-color-adjust: exact !important;\n  font-weight: bold !important; \n  text-align: center !important; \n}\n\n.bc-grid .v { \n  background: #f0f1f3 !important;\n  -webkit-print-color-adjust: exact !important; \n  print-color-adjust: exact !important; \n  text-align: center !important; \n  height: 14px !important; \n}\n\n.bc-lead { \n  margin: 0 0 6px 0 !important; \n  font-size: 9.5pt !important; \n}\n\n/* Modification de la section Tableau (Conforme à l'image modèle) */\n.bc-items { width: 100% !important; }\n.bc-items th {\n  background: #2c3e50 !important; \n  color: #fff !important;\n  -webkit-print-color-adjust: exact !important; \n  print-color-adjust: exact !important;\n  padding: 5px 6px !important; \n  font-size: 8.5pt !important; \n  text-align: center !important;\n  border: 1px solid #c9ced4 !important;\n}\n\n.bc-items td { \n  border: 1px solid #c9ced4 !important; \n  padding: 4px 6px !important; \n  font-size: 9pt !important; \n  height: 16px !important; \n}\n.bc-items .c { text-align: center !important; }\n.bc-items .r { text-align: right !important; }\n\n/* Totaux */\n.bc-tot-wrapper {\n  width: 100% !important;\n  display: block !important;\n  margin-top: -1px !important;\n  margin-bottom: 15px !important;\n}\n\n.bc-tot { \n  width: 46% !important; \n  float: right !important; \n  border-collapse: collapse !important;\n}\n\n.bc-tot td { \n  border: 1px solid #c9ced4 !important; \n  padding: 4px 8px !important; \n  font-size: 9pt !important;\n  background: #ececec !important;\n  -webkit-print-color-adjust: exact !important; \n  print-color-adjust: exact !important; \n}\n.bc-tot .lbl { text-align: right !important; font-weight: bold !important; width: 55% !important; }\n.bc-tot .val { text-align: right !important; }\n.bc-tot .ttc td { font-weight: bold !important; font-size: 10pt !important; }\n\n/* Section Commentaire (Espace augmenté) */\n.bc-sa { \n  color: #2c3e50 !important; \n  font-weight: bold !important; \n  font-size: 9.5pt !important; \n  border-top: 2px solid #c9ced4 !important; \n  padding-top: 5px !important; \n}\n\n.bc-com {\n  background: #2c3e50 !important; \n  color: #fff !important;\n  -webkit-print-color-adjust: exact !important; \n  print-color-adjust: exact !important;\n  text-align: center !important; \n  font-weight: bold !important; \n  font-size: 9pt !important; \n  padding: 5px !important; \n  margin-top: 4px !important;\n}\n\n.bc-com-box { \n  border: 1px solid #c9ced4 !important; \n  border-top: none !important; \n  padding: 12px 15px !important;\n  min-height: 130px !important; /* Hauteur augmentée pour ajouter de l'espace */\n  font-size: 9.5pt !important; \n}\n\n/* Pied de page calé de manière absolue */\n.bc-foot { \n  position: absolute !important;\n  bottom: 0 !important;\n  left: 0 !important;\n  width: 100% !important;\n  border-top: 1px solid #c9ced4 !important; \n  padding-top: 5px !important;\n  text-align: center !important; \n  font-size: 7.5pt !important; \n  color: #555 !important; \n  line-height: 1.4 !important; \n}",
